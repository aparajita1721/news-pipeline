# .env.example
# Copy this file to .env and fill in your values.
# NEVER commit .env to GitHub — it contains secrets!
#
# How to get a free NewsAPI key:
#   1. Go to https://newsapi.org
#   2. Click "Get API Key"
#   3. Sign up (free) — you get 100 requests/day
#   4. Copy your key and paste it below

NEWSAPI_KEY=your_newsapi_key_here

# These are pre-filled for local Docker development — no changes needed
DATABASE_URL=postgresql://airflow:airflow@postgres:5432/newsdb
